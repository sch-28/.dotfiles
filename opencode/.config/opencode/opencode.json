 {
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "rm *": "ask",
      "git *": "allow",
      "git commit *": "deny",
      "git push *": "deny",
      "grep *": "allow",
      "find *": "allow",
      "head *": "allow",
      "ls *": "allow"
    },
    "edit": {
      "*": "ask",
    },
     "read": {
      "*": "allow",
      "*.env": "deny",
      ".env.": "deny",
      "*.env.example": "allow"
    }
  }
}
